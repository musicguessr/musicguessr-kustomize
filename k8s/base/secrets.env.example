# Copy this file to secrets.env and fill in real values.
# secrets.env is gitignored — never commit real credentials.

# Apple Music developer token (MusicKit JWT, signed with Apple private key, valid 6 months)
APPLE_DEV_TOKEN=

# Discogs API personal access token (optional — enables Discogs as metadata source)
# Get one at: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# S3-compatible object storage credentials for deck persistence (optional)
# Required only when DECK_STORAGE_PROVIDER=s3 in the backend ConfigMap.
# Compatible with Cloudflare R2, AWS S3, MinIO, etc.
DECK_STORAGE_ACCESS_KEY_ID=
DECK_STORAGE_SECRET_ACCESS_KEY=
